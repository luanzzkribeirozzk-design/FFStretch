<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050510">

    <!-- Particle Canvas -->
    <com.lnstretch.ParticleView
        android:id="@+id/particleView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="50dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="40dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LN"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:textColor="#FF4500"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S T R E T C H"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B00"
                    android:letterSpacing="0.5"
                    android:layout_marginTop="-8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Esticador de tela para Free Fire"
                    android:textSize="11sp"
                    android:textColor="#33334A"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- SHIZUKU + STATUS CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#0C0C1E"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SHIZUKU"
                                android:textSize="9sp"
                                android:textColor="#FF4500"
                                android:letterSpacing="0.3"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvShizukuStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Verificando..."
                                android:textSize="13sp"
                                android:textColor="#CCCCEE"
                                android:layout_marginTop="3dp" />

                        </LinearLayout>

                        <Button
                            android:id="@+id/btnShizuku"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:text="AUTORIZAR"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:backgroundTint="#FF4500" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#18182A"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STATUS"
                        android:textSize="9sp"
                        android:textColor="#7C00FF"
                        android:letterSpacing="0.3"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Carregando..."
                        android:textSize="13sp"
                        android:textColor="#AAAACC"
                        android:layout_marginTop="4dp"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- SLIDER CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#0C0C1E"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="INTENSIDADE"
                            android:textSize="9sp"
                            android:textColor="#FF4500"
                            android:letterSpacing="0.3"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1% - 40%"
                            android:textSize="10sp"
                            android:textColor="#33334A" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSliderLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="+15%"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="6dp" />

                    <SeekBar
                        android:id="@+id/seekbarStretch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:progressTint="#FF4500"
                        android:thumbTint="#FF6B00" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1%"
                            android:textSize="10sp"
                            android:textColor="#2A2A3E"
                            android:gravity="start" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="25%"
                            android:textSize="10sp"
                            android:textColor="#2A2A3E"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="40%"
                            android:textSize="10sp"
                            android:textColor="#2A2A3E"
                            android:gravity="end" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- MODO STRETCH -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btnModoLateral"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="LATERAIS"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF4500" />

                <Button
                    android:id="@+id/btnModoVertical"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="CIMA/BAIXO"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#AAAACC"
                    android:backgroundTint="#1A1A2E" />

            </LinearLayout>

            <!-- BOTOES ESTICAR / RESTAURAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">

                <Button
                    android:id="@+id/btnStretch"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="ESTICAR"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF4500" />

                <Button
                    android:id="@+id/btnUnstretch"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="RESTAURAR"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF4500"
                    android:backgroundTint="#1A0A00" />

            </LinearLayout>

            <!-- DPI CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#0C0C1E"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="DPI"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="#7C00FF"
                            android:letterSpacing="0.3" />

                        <TextView
                            android:id="@+id/tvDpiLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="480"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:textColor="#CC88FF"
                            android:fontFamily="sans-serif-black" />

                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekbarDpi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:progressTint="#7C00FF"
                        android:thumbTint="#AA44FF" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="370" android:textSize="10sp"
                            android:textColor="#2A2A3E" android:gravity="start" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="1440" android:textSize="10sp"
                            android:textColor="#2A2A3E" android:gravity="end" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <Button
                            android:id="@+id/btnApplyDpi"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="APLICAR DPI"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#5500CC" />

                        <Button
                            android:id="@+id/btnResetDpi"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="RESETAR DPI"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#AA88FF"
                            android:backgroundTint="#120022" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- OTIMIZAR -->
            <Button
                android:id="@+id/btnOptimize"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:text="OTIMIZAR FREE FIRE"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2A006A" />

            <!-- YUTA SENSI X -->
            <Button
                android:id="@+id/btnSensi"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="10dp"
                android:text="YUTA SENSI X — GERADOR DE SENSI"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A0050" />

            <!-- FLUTUANTE -->
            <Button
                android:id="@+id/btnOpenFF"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="10dp"
                android:text="ATIVAR BOTAO FLUTUANTE"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF6B00" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>
