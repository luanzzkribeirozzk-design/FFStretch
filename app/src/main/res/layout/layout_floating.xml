<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- PAINEL COMPLETO -->
    <LinearLayout
        android:id="@+id/floatPanel"
        android:layout_width="290dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_float_panel"
        android:visibility="gone"
        android:layout_marginEnd="10dp"
        android:elevation="14dp">

        <!-- HEADER -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="54dp">

            <com.lnstretch.ParticleView
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="14dp"
                android:text="LN STRETCH"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-black" />

            <!-- Minimizar -->
            <TextView
                android:id="@+id/fabMinimize"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="46dp"
                android:text="—"
                android:textSize="14sp"
                android:textColor="#FFDD88"
                android:gravity="center" />

            <!-- Fechar -->
            <TextView
                android:id="@+id/fabClose"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="6dp"
                android:text="✕"
                android:textSize="14sp"
                android:textColor="#FF8888"
                android:gravity="center" />

        </FrameLayout>

        <!-- SHIZUKU + STATUS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/tvFloatShizuku"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Shizuku: verificando..."
                android:textSize="10sp"
                android:textColor="#AAAACC" />

            <Button
                android:id="@+id/fabShizuku"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="AUTORIZAR"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:backgroundTint="#FF4500" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvFloatStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="Resolucao: --"
            android:textSize="9sp"
            android:textColor="#444466" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#111128" />

        <!-- ABAS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tabStretch"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="STRETCH"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="#FF4500" />

            <TextView
                android:id="@+id/tabDpi"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="DPI"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#888899"
                android:gravity="center"
                android:background="#0D0D1E" />

        </LinearLayout>

        <!-- CONTEUDO ABA STRETCH -->
        <LinearLayout
            android:id="@+id/tabContentStretch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="INTENSIDADE"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:textColor="#FF4500"
                    android:letterSpacing="0.2" />

                <TextView
                    android:id="@+id/tvFloatPct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+15%"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-black" />

            </LinearLayout>

            <SeekBar
                android:id="@+id/seekbarFloat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:progressTint="#FF4500"
                android:thumbTint="#FF6B00" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="1%" android:textSize="8sp"
                    android:textColor="#2A2A3E" android:gravity="start" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="40%" android:textSize="8sp"
                    android:textColor="#2A2A3E" android:gravity="end" />
            </LinearLayout>

            <!-- MODO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnModoLateral"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="LATERAIS"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF4500" />

                <Button
                    android:id="@+id/btnModoVertical"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="CIMA/BAIXO"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#AAAACC"
                    android:backgroundTint="#1A1A2E" />

            </LinearLayout>

            <!-- ESTICAR / RESTAURAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp">

                <Button
                    android:id="@+id/fabStretch"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="ESTICAR"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF4500" />

                <Button
                    android:id="@+id/fabRestore"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="RESTAURAR"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FF4500"
                    android:backgroundTint="#1A0A00" />

            </LinearLayout>

            <Button
                android:id="@+id/fabOptimize"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="8dp"
                android:text="OTIMIZAR FREE FIRE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2A006A" />

        </LinearLayout>

        <!-- CONTEUDO ABA DPI -->
        <LinearLayout
            android:id="@+id/tabContentDpi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DPI"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:textColor="#7C00FF"
                    android:letterSpacing="0.25" />

                <TextView
                    android:id="@+id/tvFloatDpi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="480"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#CC88FF"
                    android:fontFamily="sans-serif-black" />

            </LinearLayout>

            <SeekBar
                android:id="@+id/seekbarDpi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:progressTint="#7C00FF"
                android:thumbTint="#AA44FF" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="370" android:textSize="8sp"
                    android:textColor="#2A2A3E" android:gravity="start" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="1440" android:textSize="8sp"
                    android:textColor="#2A2A3E" android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp">

                <Button
                    android:id="@+id/fabApplyDpi"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="APLICAR DPI"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#5500CC" />

                <Button
                    android:id="@+id/fabResetDpi"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="RESETAR"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#AA88FF"
                    android:backgroundTint="#120022" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- BOLINHA -->
    <FrameLayout
        android:id="@+id/fabMain"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="end"
        android:elevation="18dp"
        android:background="@drawable/bg_fab_circle">

        <com.lnstretch.ParticleView
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="LN"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-black" />

    </FrameLayout>

</FrameLayout>
