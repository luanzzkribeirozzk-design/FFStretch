<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Painel completo -->
    <LinearLayout
        android:id="@+id/floatPanel"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EE050510"
        android:padding="0dp"
        android:visibility="gone">

        <!-- Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#FF4500">

            <com.lnstretch.ParticleView
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:text="LN STRETCH"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/fabClose"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="10dp"
                android:text="X"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="#33000000" />

        </FrameLayout>

        <!-- Status Shizuku -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0C0C1E"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/tvFloatShizuku"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Shizuku: verificando..."
                android:textSize="11sp"
                android:textColor="#AAAACC" />

            <Button
                android:id="@+id/fabShizuku"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="AUTORIZAR"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:backgroundTint="#FF4500" />

        </LinearLayout>

        <!-- Status resolucao -->
        <TextView
            android:id="@+id/tvFloatStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#08081A"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="Resolucao: --"
            android:textSize="11sp"
            android:textColor="#666688" />

        <!-- Slider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0A0A18"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="INTENSIDADE"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#FF4500"
                    android:letterSpacing="0.2" />

                <TextView
                    android:id="@+id/tvFloatPct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+15%"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-black" />

            </LinearLayout>

            <SeekBar
                android:id="@+id/seekbarFloat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:progressTint="#FF4500"
                android:thumbTint="#FF6B00" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="3dp">

                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="10%" android:textSize="9sp"
                    android:textColor="#2A2A3E" android:gravity="start" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="25%" android:textSize="9sp"
                    android:textColor="#2A2A3E" android:gravity="center" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="40%" android:textSize="9sp"
                    android:textColor="#2A2A3E" android:gravity="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- Modo stretch -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MODO DE STRETCH"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#FF4500"
            android:letterSpacing="0.2"
            android:background="#050510"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#050510"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btnModoLateral"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="LATERAIS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF4500" />

            <Button
                android:id="@+id/btnModoVertical"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="CIMA/BAIXO"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#AAAACC"
                android:backgroundTint="#1A1A2E" />

        </LinearLayout>

        <!-- Botoes principais -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#050510"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp">

            <Button
                android:id="@+id/fabStretch"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="ESTICAR"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF4500" />

            <Button
                android:id="@+id/fabRestore"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="RESTAURAR"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FF4500"
                android:backgroundTint="#1A0A00" />

        </LinearLayout>

        <!-- Otimizar -->
        <Button
            android:id="@+id/fabOptimize"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="10dp"
            android:text="OTIMIZAR FREE FIRE"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A006A" />

    </LinearLayout>

    <!-- Botao flutuante mini (quando painel fechado) -->
    <FrameLayout
        android:id="@+id/fabMain"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_gravity="end"
        android:background="#FF4500"
        android:elevation="8dp">

        <com.lnstretch.ParticleView
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="LN"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-black" />

    </FrameLayout>

</FrameLayout>
